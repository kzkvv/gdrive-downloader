[
  {
    "id": 1,
    "priority": 1,
    "action": {
      "type": "modifyHeaders",
      "requestHeaders": [
        {
          "header": "origin",
          "operation": "set",
          "value": "https://youtube.googleapis.com"
        },
        {
          "header": "referer",
          "operation": "set",
          "value": "https://youtube.googleapis.com/"
        }
      ]
    },
    "condition": {
      "regexFilter": "^https://([^/]+\\.)*(googlevideo\\.com|c\\.drive\\.google\\.com)/.*videoplayback",
      "resourceTypes": [
        "media",
        "xmlhttprequest"
      ]
    }
  }
]
